# ============================================
# Deep Research Agent - 环境变量配置
# ============================================

# GitHub API Token (可选，但推荐使用以提高速率限制)
# 获取方式: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# Tavily API Key (必需)
# 获取方式: https://tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# OpenAI API Key (可选，用于 LLM 分析)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (可选，替代 OpenAI)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================
# LLM 配置
# ============================================

# LLM 提供商: openai 或 anthropic
LLM_PROVIDER=openai

# 模型名称
LLM_MODEL=gpt-4o

# 温度参数 (0-2)
LLM_TEMPERATURE=0.3

# 最大 token 数
LLM_MAX_TOKENS=4096

# ============================================
# 工具配置
# ============================================

# GitHub 分析的最大仓库数
MAX_GITHUB_REPOS=5

# 搜索结果的最大数量
MAX_SEARCH_RESULTS=10

# 工作流最大迭代次数
MAX_ITERATIONS=3
